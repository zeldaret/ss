                              static_cast<long>(sizeof(TIt)) +
                          shuffle % SHUFFLE_MAX);

        if (++shuffle >= SHUFFLE_MAX) {
            shuffle = SHUFFLE_MIN;
        }

        TIt j = last - 1;
        __sort132<TCompare&, TIt>(m, i1, j, compare);

        m = first;
        i1 = j;
        while (compare(*m, *j)) {
            m++;
        }

        do {
            i1--;

            if (m == i1) {
                break;
            }
        } while (!compare(*i1, *j));

        if (m < i1) {
            swap(*m, *i1);
            m++;

            while (true) {
