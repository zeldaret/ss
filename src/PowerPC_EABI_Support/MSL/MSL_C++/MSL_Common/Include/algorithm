                    m++;
                } else {
                    break;
                }
            }
        }

        if (m == first) {
            swap(*m, *j);
            m++;

            i1 = last;
            if (!compare(*first, *--i1)) {
                while (m != last && !compare(*first, *m)) {
                    m++;
                }

                if (m < i1) {
                    swap(*m, *i1);
                }
